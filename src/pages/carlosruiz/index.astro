---
// ============================================================
// JUSTARCHIVE DATA – EDIT THIS SECTION ONLY
// ============================================================
const PROFILE = {
  firstName: "CARLOS",
  lastName: "RUIZ",
  quote: "I like computers, science, and reading."
};

const ALBUMS = [
  {
    name: "ALBUM / (PLACES):",
    images: ["https://github.com/jequearabe/just-archive/blob/main/public/1.jpg", "https://github.com/jequearabe/just-archive/blob/main/public/2.jpg", "https://github.com/jequearabe/just-archive/blob/main/public/3.jpg"]
  },
  {
    name: "ALBUM / (SOME FOOD):",
    images: ["https://github.com/jequearabe/just-archive/blob/main/public/4.jpg", "https://github.com/jequearabe/just-archive/blob/main/public/5.jpg", "https://github.com/jequearabe/just-archive/blob/main/public/6.jpg"]
  }
];

const TRACKS = [
  { platform: "youtube", url: "https://youtu.be/Zzl20a6AmRE?si=IpAVmcd-2Ab1Xtrx ", name: "Partynextdoor - Make it to the morning" },
  { platform: "spotify", url: "https://open.spotify.com/intl-es/track/6LUGvXEAK8WxIBYK43uoTb?si=3c2335680e2845d7", name: "The Smiths - Back to the old house" },
  { platform: "applemusic", url: "https://music.apple.com/us/album/after-hours/1499378108", name: "The Weeknd - After hours (album)" }

];

const SOCIAL_LINKS = [
  { label: "Instagram", url: "https://instagram.com/carlossruuizz", icon: "fab fa-instagram" },
    { label: "Article", url: "https://www.benbest.com/lifeext/Alzheimer.html", icon: "fas fa-newspaper" },
  { label: "Github", url: "https://github.com/zektrace", icon: "fab fa-github" }
];

function validateLimits(albums) {
  let totalImages = 0;
  let warnings = [];
  for (let idx = 0; idx < albums.length; idx++) {
    const album = albums[idx];
    const count = album.images.length;
    totalImages += count;
    if (count > 25) {
      warnings.push(`⚠️ Album "${album.name}" tiene ${count} imágenes (máx 25). Se truncarán.`);
      album.images = album.images.slice(0, 25);
    }
  }
  if (totalImages > 100) {
    warnings.push(`⚠️ Total de imágenes: ${totalImages} (excede 100).`);
  }
  return { warnings, totalImages: Math.min(totalImages, 100) };
}

const { warnings } = validateLimits(ALBUMS);
if (warnings.length) console.warn("justarchive limits:", warnings);

function escapeHtml(str) {
  if (!str) return '';
  return str.replace(/[&<>]/g, function(m) {
    if (m === '&') return '&amp;';
    if (m === '<') return '&lt;';
    if (m === '>') return '&gt;';
    return m;
  });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>[CARLOS-RUIZ]</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.cdnfonts.com/css/walkway-black-revoblique" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/telegraf" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/chivo-mono" rel="stylesheet">
  <style>
    :root {
      --bg: #fafaf9;
      --text: #1a1a1a;
      --text-muted: #4a4a4a;
      --border: #e5e5e5;
      --card-bg: #ffffff;
      --quote-border: #1a1a1a;
      --footer-text: #9a9a9a;
      --accent: #000000;
    }
    [data-theme="dark"] {
      --bg: #000000;
      --text: #f5f5f0;
      --text-muted: #b0b0b0;
      --border: #2a2a2a;
      --card-bg: #0c0c0c;
      --quote-border: #f5f5f0;
      --footer-text: #5a5a5a;
      --accent: #ffffff;
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Chivo Mono', monospace;
      line-height: 1.5;
      padding: 2.5rem 1.5rem;
      transition: background-color 0.3s ease, color 0.2s ease;
    }
    .container {
      max-width: 1280px;
      margin: 0 auto;
    }
    .theme-toggle {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 60px;
      padding: 0.75rem 1rem;
      cursor: pointer;
      font-size: 1.2rem;
      z-index: 100;
      backdrop-filter: blur(8px);
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      transition: transform 0.2s, background 0.2s;
      color: var(--text);
    }
    .theme-toggle:hover {
      transform: scale(1.05);
    }
    .name-block {
      margin: 2rem 0 1rem 0;
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .name-line {
      font-family: 'Telegraf', sans-serif;
      font-size: 4.2rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.1;
      text-transform: uppercase;
    }
    .badge {
      font-family: 'Chivo Mono', monospace;
      font-size: 0.7rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 40px;
      padding: 0.2rem 0.7rem;
      margin-left: 0.8rem;
      vertical-align: middle;
      color: var(--text-muted);
      letter-spacing: 0;
      text-transform: none;
      font-weight: normal;
    }
    @media (max-width: 600px) {
      .name-line {
        font-size: 2.8rem;
      }
      body {
        padding: 1.5rem 1.2rem;
      }
      .badge {
        font-size: 0.6rem;
        margin-left: 0.3rem;
      }
    }
    .quote-desc {
      font-style: italic;
      color: var(--text-muted);
      border-left: 2px solid var(--quote-border);
      padding-left: 1.2rem;
      margin: 1rem 0 2.5rem 0;
      font-size: 1.1rem;
      max-width: 600px;
      animation: fadeInUp 0.6s ease-out;
    }
    .albums-section {
      margin: 3rem 0 2rem 0;
    }
    .album-title {
      font-family: 'Chivo Mono', monospace;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      font-weight: 500;
    }
    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .image-card {
      background-color: var(--card-bg);
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 12px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      animation: fadeInScale 0.5s ease backwards;
      animation-delay: calc(0.05s * var(--i, 0));
    }
    .image-card:hover {
      transform: translateY(-5px) scale(1.02);
      box-shadow: 0 12px 20px rgba(0,0,0,0.2);
    }
    .image-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: filter 0.3s;
    }
    .image-card:hover img {
      filter: brightness(1.05);
    }
    .info-columns {
      display: flex;
      flex-wrap: wrap;
      gap: 2.5rem;
      margin: 2rem 0 2rem;
      /* bordes eliminados para evitar duplicados */
    }
    .tracks-col, .social-col {
      flex: 1;
      min-width: 200px;
    }
    .col-head {
      font-family: 'Chivo Mono', monospace;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
      font-weight: 500;
    }
    .track-list {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }
    .track-item a {
      color: var(--text);
      text-decoration: none;
      font-size: 0.95rem;
      border-bottom: 1px dotted var(--border);
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: border-color 0.2s;
    }
    .track-item a:hover {
      border-bottom-color: var(--accent);
    }
    .track-name {
      display: inline-block;
      transition: transform 0.2s ease;
    }
    .track-item a:hover .track-name {
      transform: translateX(4px);
    }
    /* Social icons en lista vertical */
    .social-icons {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .social-icons a {
      color: var(--text);
      font-size: 1rem;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      transition: transform 0.2s, color 0.2s;
    }
    .social-icons a:hover {
      transform: translateX(4px);
      color: var(--accent);
    }
    .social-icons a span {
      font-size: 0.85rem;
      font-family: 'Chivo Mono', monospace;
    }
    footer {
      margin-top: 3rem;
      font-size: 0.7rem;
      text-align: center;
      color: var(--footer-text);
      border-top: 1px solid var(--border);
      padding-top: 2rem;
    }
    .footer-logo {
      font-family: 'Walkway Black RevOblique', 'Walkway Black', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 4px;
      margin-bottom: 1rem;
      color: var(--text-muted);
    }
    footer a {
      color: var(--text-muted);
      text-decoration: none;
      border-bottom: 1px dotted var(--border);
    }
    footer a:hover {
      color: var(--text);
    }
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(15px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes fadeInScale {
      from {
        opacity: 0;
        transform: scale(0.96);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
    @media (max-width: 700px) {
      .image-grid {
        gap: 1rem;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      }
      .info-columns {
        flex-direction: column;
        gap: 2rem;
      }
      .theme-toggle {
        bottom: 1rem;
        right: 1rem;
        padding: 0.6rem 0.9rem;
      }
      .footer-logo {
        font-size: 1.2rem;
      }
    }
  </style>
</head>
<body>
<div class="container">
  <div class="name-block">
    <div class="name-line">{escapeHtml(PROFILE.firstName)} <div>{escapeHtml(PROFILE.lastName)}.</div></div>
    
  </div>
  <div class="quote-desc">{escapeHtml(PROFILE.quote)}</div>

  {
    ALBUMS.length > 0 ? (
      <div class="albums-section">
        {ALBUMS.map(album => (
          <div>
            <div class="album-title">{escapeHtml(album.name)}</div>
            <div class="image-grid">
              {album.images.slice(0, 25).map((imgPath, idx) => (
                <div class="image-card" style={`--i: ${idx}`}>
                  <img src={escapeHtml(imgPath)} alt="archive" loading="lazy" />
                </div>
              ))}
              {album.images.length === 0 && <div style="color: var(--text-muted); font-size:0.75rem;">— empty —</div>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div style="margin: 1rem 0; color: var(--text-muted);">no albums yet</div>
    )
  }

  <div class="info-columns">
    <div class="tracks-col">
      <div class="col-head">TRACKS</div>
      <div class="track-list">
        {TRACKS.length === 0 ? (
          <span style="color: var(--text-muted);">—</span>
        ) : (
          TRACKS.map(track => {
            let platformIcon = '';
            if (track.platform === 'spotify') platformIcon = '<i class="fab fa-spotify"></i>';
            else if (track.platform === 'applemusic') platformIcon = '<i class="fab fa-apple"></i>';
            else if (track.platform === 'youtube') platformIcon = '<i class="fab fa-youtube"></i>';
            return (
              <div class="track-item">
                <a href={escapeHtml(track.url)} target="_blank" rel="noopener noreferrer">
                  <span set:html={platformIcon}></span>
                  <span class="track-name">{escapeHtml(track.name)}</span>
                </a>
              </div>
            );
          })
        )}
      </div>
    </div>
    <div class="social-col">
      <div class="col-head">SOCIAL MEDIA</div>
      <div class="social-icons">
        {SOCIAL_LINKS.map(link => (
          <a href={escapeHtml(link.url)} target="_blank" rel="noopener noreferrer">
            <i class={link.icon}></i> <span>{escapeHtml(link.label)}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <footer>
    <div class="footer-logo"><a href="/">[JUST-ARCHIVE]</a></div>
    <div>Developed by<a href="https://github.com/zektrace" target="_blank"> Carlos Ruiz</a>
    {warnings.length > 0 && ` · ${escapeHtml(warnings[0])}`}</div>
  </footer>
</div>

<button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema">
  <i class="fas fa-moon"></i>
</button>

<script>
  const themeToggle = document.getElementById('themeToggle');
  const icon = themeToggle.querySelector('i');
  function setTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (theme === 'dark') {
      icon.classList.remove('fa-moon');
      icon.classList.add('fa-sun');
    } else {
      icon.classList.remove('fa-sun');
      icon.classList.add('fa-moon');
    }
  }
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) {
    setTheme(savedTheme);
  } else {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    setTheme(prefersDark ? 'dark' : 'light');
  }
  themeToggle.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const newTheme = current === 'dark' ? 'light' : 'dark';
    setTheme(newTheme);
  });
</script>
</body>
</html>
