<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>[JUST-ARCHIVE]</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.cdnfonts.com/css/walkway-black-revoblique" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/telegraf" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/chivo-mono" rel="stylesheet">
  <link rel="stylesheet" href="/src/styles/global.css">
  <style>
    /* Estilos específicos de la landing */
    .hero {
      text-align: center;
      max-width: 700px;
      margin: 2rem auto;
    }
    .logo {
      font-size: 3rem;
      margin-bottom: 1rem;
      color: var(--text-muted);
    }
    .tagline {
      font-family: "Telegraf", sans-serif;
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }
    .beta-badge {
      display: inline-block;
      background: var(--card-bg);
      border: 1px solid var(--border);
      padding: 0.2rem 0.8rem;
      border-radius: 20px;
      font-size: 0.7rem;
      letter-spacing: 1px;
      margin-bottom: 1.5rem;
      color: var(--text-muted);
    }
    .auth-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 2rem;
      max-width: 450px;
      margin: 2rem auto;
      transition: box-shadow 0.2s;
    }
    .tabs {
      display: flex;
      gap: 1rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .tab {
      background: none;
      border: none;
      padding: 0.5rem 1rem;
      font-family: "Chivo Mono", monospace;
      cursor: pointer;
      color: var(--text-muted);
      transition: color 0.2s;
    }
    .tab.active {
      color: var(--accent);
      border-bottom: 2px solid var(--accent);
    }
    .form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    input {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      padding: 0.75rem;
      font-family: "Chivo Mono", monospace;
      color: var(--text);
    }
    button[type="submit"] {
      background: var(--accent);
      color: var(--bg);
      border: none;
      padding: 0.75rem;
      border-radius: 0.5rem;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.2s;
    }
    button[type="submit"]:hover {
      background: var(--accent-hover);
    }
    .message {
      font-size: 0.8rem;
      text-align: center;
    }
    footer {
      text-align: center;
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      font-size: 0.7rem;
      color: var(--footer-text);
    }
    footer a {
      color: var(--text-muted);
      text-decoration: none;
      border-bottom: 1px dotted var(--border);
    }
  </style>
</head>
<body>
<div class="container">
  <div class="hero fade-up">
    <div class="logo logo-brand">[JUST-ARCHIVE]</div>
    <div class="tagline">archive your presence</div>
    <div class="beta-badge">BETA / 2025</div>
  </div>

  <div class="auth-card">
    <div class="tabs">
      <button class="tab active" data-tab="login">LOGIN</button>
      <button class="tab" data-tab="register">REGISTER</button>
    </div>

    <form id="loginForm" class="form">
      <input type="email" id="loginEmail" placeholder="email" required>
      <input type="password" id="loginPassword" placeholder="password" required>
      <button type="submit">→ enter</button>
      <div id="loginMessage" class="message"></div>
    </form>

    <form id="registerForm" class="form" style="display: none;">
      <input type="email" id="registerEmail" placeholder="email" required>
      <input type="password" id="registerPassword" placeholder="password" required>
      <button type="submit">→ create</button>
      <div id="registerMessage" class="message"></div>
    </form>
  </div>

  <footer>
    <div class="logo-brand" style="font-size: 1.2rem; margin-bottom: 0.5rem;">[JA]</div>
    <p>developed by <a href="#">zektrace</a> — build your own archive</p>
  </footer>
</div>

<button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>

<script>
  // Theme
  const setTheme = (t) => { document.documentElement.setAttribute('data-theme', t); localStorage.setItem('theme', t); };
  const saved = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  setTheme(saved);
  const themeBtn = document.getElementById('themeToggle');
  themeBtn.onclick = () => {
    const cur = document.documentElement.getAttribute('data-theme');
    setTheme(cur === 'dark' ? 'light' : 'dark');
  };

  // Tabs
  const tabs = document.querySelectorAll('.tab');
  const loginForm = document.getElementById('loginForm');
  const registerForm = document.getElementById('registerForm');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      if (tab.dataset.tab === 'login') {
        loginForm.style.display = 'flex';
        registerForm.style.display = 'none';
      } else {
        loginForm.style.display = 'none';
        registerForm.style.display = 'flex';
      }
    });
  });

  function showMessage(el, text, isErr = true) {
    el.innerHTML = `<span style="color:${isErr ? '#ef4444' : '#10b981'}">${text}</span>`;
    setTimeout(() => el.innerHTML = '', 4000);
  }

  // Register
  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('registerEmail').value;
    const pass = document.getElementById('registerPassword').value;
    const res = await fetch('/api/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pass })
    });
    const data = await res.json();
    if (res.ok) {
      showMessage(document.getElementById('registerMessage'), 'registered! now login.', false);
      document.querySelector('[data-tab="login"]').click();
      registerForm.reset();
    } else {
      showMessage(document.getElementById('registerMessage'), data.error || 'error');
    }
  });

  // Login
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('loginEmail').value;
    const pass = document.getElementById('loginPassword').value;
    const res = await fetch('/api/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pass })
    });
    const data = await res.json();
    if (res.ok) {
      localStorage.setItem('token', data.token);
      localStorage.setItem('user', JSON.stringify(data.user));
      window.location.href = '/dashboard';
    } else {
      showMessage(document.getElementById('loginMessage'), data.error || 'invalid credentials');
    }
  });
</script>
</body>
</html>